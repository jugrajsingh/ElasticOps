# =============================================================================
# Makefile.test - Local 3-node Elasticsearch test cluster + seeding
# =============================================================================
# Usage: make -f Makefile.test <target>
# =============================================================================

COMPOSE_FILE := docker-compose.test.yaml

.DEFAULT_GOAL := help

.PHONY: help test-cluster-up test-cluster-down

help:  ## Show available targets
	@grep -E '^[a-zA-Z_-]+:.*?## ' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-22s\033[0m %s\n", $$1, $$2}'

test-cluster-up:  ## Start the 3-node ES test cluster
	docker compose -f $(COMPOSE_FILE) up -d

test-cluster-down:  ## Stop and remove the test cluster (and volumes)
	docker compose -f $(COMPOSE_FILE) down -v
